# =========================================
# TechBird Web - .gitignore
# Organization standard + project-specific
# =========================================

# -------------------------
# OS generated files
# -------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# -------------------------
# Logs
# -------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -------------------------
# Environment / Secrets
# -------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets.json
credentials.json
service-account.json

# -------------------------
# IDE / Editors
# -------------------------
.vscode/
.idea/
*.iml

# -------------------------
# Node / React
# -------------------------
node_modules/
dist/
build/
.next/
out/
coverage/

# -------------------------
# Vite
# -------------------------
.vite/

# -------------------------
# Python
# -------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
env/
.venv/
.pytest_cache/
.mypy_cache/

# -------------------------
# Frappe / ERPNext
# -------------------------
sites/assets
sites/*/private/files
sites/*/public/files
sites/*/logs
sites/.build
sites/.cache

# -------------------------
# Docker
# -------------------------
docker-data/
*.tar

# -------------------------
# Temporary files
# -------------------------
tmp/
temp/
*.tmp
.cache/

# -------------------------
# Build artifacts
# -------------------------
*.zip
*.tar.gz
*.rar

# -------------------------
# AI tools / Agent generated
# -------------------------

# Anthropic / Claude
.claude/
claude-settings.json
claude_settings.json
.claude_files/

# Google Gemini / Antigravity / IDX
.gemini/
.idx/

# OpenAI / Codex / ChatGPT
.codex/
.openai/
.chatgpt/

# Cursor editor
.cursor/
.cursorignore
.cursorindexingignore

# Windsurf (Codeium)
.windsurf/
.codeium/

# Kilo Code
.kilocode/

# Cline / Roo Cline
.cline/
.roo/

# Continue.dev
.continue/

# Aider
.aider*
aider.conf.yml

# GitHub Copilot
.copilot/

# Tabnine
.tabnine/

# Supermaven
.supermaven/

# Amp
.amp/

# Devin
.devin/

